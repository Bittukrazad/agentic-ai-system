# =============================================================================
# .env.development — Local Development Environment
# =============================================================================
# Copy this file to .env for local development:
#   cp .env.development .env
#
# Everything runs in mock/local mode:
#   - LLM      → mock (realistic fake responses, no API key needed)
#   - Database → SQLite file in project root
#   - Redis    → in-process queue (no Redis server needed)
#   - Slack    → logged to terminal
#   - Email    → logged to terminal
#   - Calendar → logged to terminal
# =============================================================================

# ── LLM ──────────────────────────────────────────────────────────────────────
# mock mode: realistic fake responses, zero cost, no internet required
LLM_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=1500

# To switch to a real LLM during development, uncomment one block:
#
# --- OpenAI ---
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-your-key-here
# LLM_MODEL=gpt-4o
#
# --- Anthropic ---
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# LLM_MODEL=claude-sonnet-4-6

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./agentic_ai.db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# ── Slack (mock mode — messages go to log) ────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#enterprise-alerts
SLACK_ESCALATION_CHANNEL=#manager-alerts
SLACK_HEALTH_CHANNEL=#workflow-health
SLACK_WORKSPACE=dev-workspace

# ── Email (mock mode — emails go to log) ──────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Agentic AI (Dev)
MANAGER_EMAIL=manager@company.com
ADMIN_EMAIL=admin@company.com

# ── Google Calendar (mock mode — events go to log) ───────────────────────────
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_TOKEN=./google_token.json
GOOGLE_CALENDAR_ID=primary

# ── External APIs (mock data used when blank) ─────────────────────────────────
HRMS_API_URL=
HRMS_API_KEY=
ERP_API_URL=
ERP_API_KEY=
CRM_API_URL=
CRM_API_KEY=
EXTERNAL_API_TIMEOUT=30

# ── Agent Behaviour ───────────────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.7
MAX_RETRIES=3
SLA_TIMEOUT_MINUTES=30
BASE_RETRY_DELAY=1.0
MAX_RETRY_DELAY=30.0
SLA_MEETING_HOURS=1
SLA_ONBOARDING_HOURS=48
SLA_PROCUREMENT_HOURS=72
SLA_CONTRACT_HOURS=96

# ── Health Monitoring ─────────────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL_MINUTES=5
DRIFT_MULTIPLIER=1.5
BREACH_TRIGGER_THRESHOLD=0.70
ANOMALY_RETRY_THRESHOLD=3
ANOMALY_ERROR_THRESHOLD=2
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG for development — see every agent action as it happens
LOG_LEVEL=DEBUG
LOG_FORMAT=text
LOG_FILE=
LOG_INCLUDE_CONTEXT=true

# ── Application Server ────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
WORKERS=1
REQUEST_TIMEOUT=60
DASHBOARD_PORT=8501
CORS_ORIGINS=*

# ── Security (relaxed for local dev) ──────────────────────────────────────────
SECRET_KEY=dev-secret-key-not-for-production
API_KEY=
RATE_LIMIT_PER_MINUTE=0
