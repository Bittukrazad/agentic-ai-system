# =============================================================================
# AGENTIC AI — AUTONOMOUS ENTERPRISE WORKFLOWS
# Environment Variable Reference
# =============================================================================
#
# USAGE:
#   cp .env.example .env        # for local development
#   cp .env.example .env.prod   # for production (fill in real values)
#
# QUICK START (no API key needed):
#   Set LLM_PROVIDER=mock — the system runs fully in demo mode.
#   All agent decisions are answered with realistic mock responses.
#   Slack and email send to logs instead of real channels.
#
# SECTIONS:
#   1. LLM Provider
#   2. Database
#   3. Redis / Message Queue
#   4. Slack Integration
#   5. Email (SMTP)
#   6. Google Calendar
#   7. External Enterprise APIs
#   8. Agent Behaviour Tuning
#   9. Health Monitoring
#  10. Logging
#  11. Application Server
#  12. Security
# =============================================================================


# -----------------------------------------------------------------------------
# 1. LLM PROVIDER
# Choose one provider. Set the matching API key.
# Without a key, set LLM_PROVIDER=mock — full demo mode, no API calls.
# -----------------------------------------------------------------------------

# Provider: openai | anthropic | mock
LLM_PROVIDER=mock

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Model to use
# OpenAI options:    gpt-4o | gpt-4o-mini | gpt-4-turbo
# Anthropic options: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
LLM_MODEL=gpt-4o

# Maximum tokens per LLM response (controls cost and latency)
LLM_MAX_TOKENS=1500


# -----------------------------------------------------------------------------
# 2. DATABASE
# SQLite is the default — works out of the box, no server needed.
# Switch to PostgreSQL for multi-instance or production deployments.
# -----------------------------------------------------------------------------

# SQLite (default)
DATABASE_URL=sqlite:///./agentic_ai.db

# PostgreSQL (production)
# DATABASE_URL=postgresql://user:password@localhost:5432/agentic_ai

# MySQL (alternative)
# DATABASE_URL=mysql+pymysql://user:password@localhost:3306/agentic_ai


# -----------------------------------------------------------------------------
# 3. REDIS / MESSAGE QUEUE
# Redis is optional. Without it, the system uses an in-process queue.
# Required for multi-instance deployments and persistent queues.
# -----------------------------------------------------------------------------

REDIS_URL=redis://localhost:6379/0

# Redis with authentication (production)
# REDIS_URL=redis://:yourpassword@redis-host:6379/0

# Redis SSL (Upstash, Redis Enterprise)
# REDIS_URL=rediss://default:password@your-redis-host:6380/0

# true = require Redis  |  false = fall back to in-process queue
REDIS_ENABLED=false


# -----------------------------------------------------------------------------
# 4. SLACK INTEGRATION
# Without a token, Slack messages are printed to the application log.
# Setup: api.slack.com/apps → Bot Token Scopes: chat:write, users:read
# -----------------------------------------------------------------------------

SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here
SLACK_CHANNEL=#enterprise-alerts
SLACK_ESCALATION_CHANNEL=#manager-alerts
SLACK_HEALTH_CHANNEL=#workflow-health
SLACK_WORKSPACE=your-workspace


# -----------------------------------------------------------------------------
# 5. EMAIL (SMTP)
# Without credentials, emails are printed to the application log.
# Gmail: use an App Password (not your account password).
#   myaccount.google.com/apppasswords
# SendGrid: SMTP_HOST=smtp.sendgrid.net  SMTP_USER=apikey
# -----------------------------------------------------------------------------

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_FROM_NAME=Agentic AI System
MANAGER_EMAIL=manager@company.com
ADMIN_EMAIL=admin@company.com


# -----------------------------------------------------------------------------
# 6. GOOGLE CALENDAR
# Without credentials, calendar events are printed to the application log.
# Setup: console.cloud.google.com → Enable Calendar API → OAuth 2.0 Client
# -----------------------------------------------------------------------------

GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_TOKEN=./google_token.json
GOOGLE_CALENDAR_ID=primary


# -----------------------------------------------------------------------------
# 7. EXTERNAL ENTERPRISE APIs
# Without these, the system uses built-in mock data.
# -----------------------------------------------------------------------------

# HRMS (Workday, BambooHR) — employee records
HRMS_API_URL=
HRMS_API_KEY=

# ERP (SAP, Oracle) — vendor and procurement data
ERP_API_URL=
ERP_API_KEY=

# CRM (Salesforce, HubSpot) — contract and customer data
CRM_API_URL=
CRM_API_KEY=

# Timeout in seconds for all external API calls
EXTERNAL_API_TIMEOUT=30


# -----------------------------------------------------------------------------
# 8. AGENT BEHAVIOUR TUNING
# Control how agents decide, retry, and escalate — without touching code.
# -----------------------------------------------------------------------------

# Minimum confidence score (0.0-1.0) to proceed without retry
# Below this threshold → retry → human gate
CONFIDENCE_THRESHOLD=0.7

# Max LLM retry attempts before escalating to the human gate
MAX_RETRIES=3

# Minutes to wait for human approval at the human gate
# After this → step is auto-skipped with TIMEOUT flag
SLA_TIMEOUT_MINUTES=30

# Base retry backoff delay in seconds (doubles each attempt)
BASE_RETRY_DELAY=1.0

# Maximum backoff wait per retry (caps exponential growth)
MAX_RETRY_DELAY=30.0

# SLA durations by workflow type (hours)
SLA_MEETING_HOURS=1
SLA_ONBOARDING_HOURS=48
SLA_PROCUREMENT_HOURS=72
SLA_CONTRACT_HOURS=96


# -----------------------------------------------------------------------------
# 9. HEALTH MONITORING
# The parallel SLA watchdog: drift detection, breach prediction, rerouting.
# -----------------------------------------------------------------------------

# How often (minutes) to run health checks
HEALTH_CHECK_INTERVAL_MINUTES=5

# Drift threshold: flag step if it runs > this multiple of baseline
# 1.5 = flag if 50% slower than normal
DRIFT_MULTIPLIER=1.5

# Breach probability threshold: trigger rerouting above this (0.0-1.0)
BREACH_TRIGGER_THRESHOLD=0.70

# Anomaly flag thresholds
ANOMALY_RETRY_THRESHOLD=3
ANOMALY_ERROR_THRESHOLD=2

# Circuit breaker: open after this many consecutive failures
CIRCUIT_BREAKER_THRESHOLD=5

# Circuit breaker: seconds in OPEN state before probing HALF_OPEN
CIRCUIT_BREAKER_RECOVERY_SECONDS=60


# -----------------------------------------------------------------------------
# 10. LOGGING
# Controls what appears in your terminal and log files.
# -----------------------------------------------------------------------------

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# text | json (json is better for log aggregation: Datadog, CloudWatch)
LOG_FORMAT=text

# Log file path — blank = stdout only
LOG_FILE=

# Include workflow_id and agent_id in every log line
LOG_INCLUDE_CONTEXT=true


# -----------------------------------------------------------------------------
# 11. APPLICATION SERVER
# FastAPI + Uvicorn settings.
# -----------------------------------------------------------------------------

APP_HOST=0.0.0.0
APP_PORT=8000

# Hot-reload — development only, never use in production
DEBUG=true

# Uvicorn worker count — keep at 1 in dev (shared in-memory state)
WORKERS=1

# Request timeout in seconds
REQUEST_TIMEOUT=60

# Streamlit dashboard port
DASHBOARD_PORT=8501

# CORS origins — use * for dev, exact origins for production
CORS_ORIGINS=*


# -----------------------------------------------------------------------------
# 12. SECURITY
# Required for production. Not needed for local development.
# -----------------------------------------------------------------------------

# Secret key for tokens/sessions (generate: openssl rand -hex 32)
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# API key required on all requests (blank = disabled)
# Clients must pass: Authorization: Bearer <API_KEY>
API_KEY=

# Rate limiting — max requests per minute per IP (0 = disabled)
RATE_LIMIT_PER_MINUTE=0
