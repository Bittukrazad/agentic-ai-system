{
  "name": "contract_lifecycle",
  "description": "End-to-end contract management workflow from creation through renewal and termination",
  "version": "1.0",
  "sla_hours": 72,
  "steps": [
    {
      "step_id": "receive_contract_request",
      "name": "Receive Contract Request",
      "type": "data_agent",
      "description": "Load contract request with all requirements",
      "action": "load_contract_request",
      "dependencies": [],
      "timeout_seconds": 60
    },
    {
      "step_id": "validate_contract_terms",
      "name": "Validate Contract Terms",
      "type": "verification_agent",
      "description": "Verify all required terms and legal compliance",
      "action": "validate_contract_terms",
      "dependencies": ["receive_contract_request"],
      "timeout_seconds": 120
    },
    {
      "step_id": "route_for_approval",
      "name": "Route for Approval",
      "type": "decision_agent",
      "description": "Determine approval routing based on contract value",
      "action": "determine_approval_routing",
      "dependencies": ["validate_contract_terms"],
      "timeout_seconds": 60
    },
    {
      "step_id": "manager_approval",
      "name": "Manager Approval",
      "type": "action_agent",
      "description": "Send to manager for review and approval",
      "action": "request_manager_approval",
      "dependencies": ["route_for_approval"],
      "timeout_seconds": 3600
    },
    {
      "step_id": "legal_review",
      "name": "Legal Review",
      "type": "action_agent",
      "description": "Route to legal team for compliance review",
      "action": "request_legal_review",
      "dependencies": ["route_for_approval"],
      "timeout_seconds": 7200
    },
    {
      "step_id": "executive_approval",
      "name": "Executive Approval",
      "type": "action_agent",
      "description": "Route to executive for final approval",
      "action": "request_executive_approval",
      "dependencies": ["manager_approval", "legal_review"],
      "timeout_seconds": 3600
    },
    {
      "step_id": "prepare_final_document",
      "name": "Prepare Final Document",
      "type": "action_agent",
      "description": "Generate final contract with approved terms",
      "action": "prepare_final_document",
      "dependencies": ["executive_approval"],
      "timeout_seconds": 300
    },
    {
      "step_id": "send_for_signature",
      "name": "Send for Signature",
      "type": "action_agent",
      "description": "Route to digital signature service",
      "action": "send_for_signature",
      "dependencies": ["prepare_final_document"],
      "timeout_seconds": 600
    },
    {
      "step_id": "monitor_signatures",
      "name": "Monitor Signatures",
      "type": "monitoring_agent",
      "description": "Track signature progress and send reminders",
      "action": "monitor_signatures",
      "dependencies": ["send_for_signature"],
      "timeout_seconds": 86400
    },
    {
      "step_id": "file_contract",
      "name": "File Contract",
      "type": "action_agent",
      "description": "Archive signed contract in document management system",
      "action": "file_contract",
      "dependencies": ["monitor_signatures"],
      "timeout_seconds": 300
    },
    {
      "step_id": "schedule_renewal_reminder",
      "name": "Schedule Renewal Reminder",
      "type": "action_agent",
      "description": "Create calendar alert before contract expiration",
      "action": "schedule_renewal_reminder",
      "dependencies": ["file_contract"],
      "timeout_seconds": 60
    },
    {
      "step_id": "log_completion",
      "name": "Log Completion",
      "type": "communication_agent",
      "description": "Record in audit trail",
      "action": "log_completion",
      "dependencies": ["schedule_renewal_reminder"],
      "timeout_seconds": 30
    }
  ],
  "conditional_routes": [
    {
      "from_step": "route_for_approval",
      "condition": {
        "type": "and",
        "conditions": [
          {"field": "contract_value", "operator": "greater_than", "value": 100000}
        ]
      },
      "true_step": "executive_approval",
      "false_step": "manager_approval"
    }
  ],
  "parallel_steps": [
    ["manager_approval", "legal_review"]
  ],
  "timeout_seconds": 604800,
  "max_retries": 1,
  "enabled": true
}
