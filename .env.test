# =============================================================================
# .env.test — Test Environment
# =============================================================================
# Used automatically by the test suite via:
#   python -m unittest discover -s tests
#
# All external services are mocked. Tests run fully offline.
# Fast timeouts, no rate limiting, isolated SQLite DB per test run.
# =============================================================================

# ── LLM — always mock in tests ───────────────────────────────────────────────
LLM_PROVIDER=mock
OPENAI_API_KEY=test-key-not-real
ANTHROPIC_API_KEY=test-key-not-real
LLM_MODEL=gpt-4o
LLM_MAX_TOKENS=500

# ── Database — in-memory SQLite so tests never touch the dev DB ──────────────
DATABASE_URL=sqlite:///:memory:

# ── Redis — disabled, use in-process queue ────────────────────────────────────
REDIS_URL=redis://localhost:6379/15
REDIS_ENABLED=false

# ── Slack — all messages go to log ────────────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=#test-alerts
SLACK_ESCALATION_CHANNEL=#test-escalation
SLACK_HEALTH_CHANNEL=#test-health
SLACK_WORKSPACE=test

# ── Email — all emails go to log ──────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USE_TLS=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Agentic AI (Test)
MANAGER_EMAIL=manager@test.local
ADMIN_EMAIL=admin@test.local

# ── Google Calendar — mock ────────────────────────────────────────────────────
GOOGLE_CALENDAR_CREDENTIALS=
GOOGLE_CALENDAR_TOKEN=
GOOGLE_CALENDAR_ID=primary

# ── External APIs — mock data used ────────────────────────────────────────────
HRMS_API_URL=
HRMS_API_KEY=
ERP_API_URL=
ERP_API_KEY=
CRM_API_URL=
CRM_API_KEY=
EXTERNAL_API_TIMEOUT=5

# ── Agent Behaviour — faster timeouts for tests ───────────────────────────────
CONFIDENCE_THRESHOLD=0.7
MAX_RETRIES=2
SLA_TIMEOUT_MINUTES=1
BASE_RETRY_DELAY=0.01
MAX_RETRY_DELAY=0.1
SLA_MEETING_HOURS=1
SLA_ONBOARDING_HOURS=48
SLA_PROCUREMENT_HOURS=72
SLA_CONTRACT_HOURS=96

# ── Health Monitoring — tight thresholds for test assertions ──────────────────
HEALTH_CHECK_INTERVAL_MINUTES=1
DRIFT_MULTIPLIER=1.5
BREACH_TRIGGER_THRESHOLD=0.70
ANOMALY_RETRY_THRESHOLD=3
ANOMALY_ERROR_THRESHOLD=2
CIRCUIT_BREAKER_THRESHOLD=3
CIRCUIT_BREAKER_RECOVERY_SECONDS=1

# ── Logging — WARNING in tests to keep output clean ──────────────────────────
LOG_LEVEL=WARNING
LOG_FORMAT=text
LOG_FILE=
LOG_INCLUDE_CONTEXT=false

# ── Application Server ────────────────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8001
DEBUG=false
WORKERS=1
REQUEST_TIMEOUT=10
DASHBOARD_PORT=8502
CORS_ORIGINS=*

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=test-secret-key-not-for-production
API_KEY=
RATE_LIMIT_PER_MINUTE=0
